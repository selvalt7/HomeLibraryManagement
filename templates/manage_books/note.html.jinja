{% extends "base.html.jinja" %}

{% block content %}
  <div class="space-y-6">
    <div class="rounded bg-white p-6 shadow-sm">
      <h1 class="text-4xl font-bold">Notatka</h1>
      <p class="mt-3 text-slate-700">Szczegóły notatki dotyczącej książki.</p>
    </div>

    <section class="rounded bg-white p-6 shadow-sm">
      <p class="text-slate-800 whitespace-pre-line">{{ note.content }}</p>
      <p class="mt-4 text-sm text-slate-500">Dodano: {{ note.created_at }}</p>
      <p class="mt-4">Książka: <a href="/book/{{ note.book.id }}/" class="text-blue-600 hover:underline">{{ note.book.title }}</a></p>
      {% if request.user.is_authenticated %}
        <a href="/note/{{ note.id }}/edit/" class="mt-6 inline-flex rounded bg-slate-800 px-4 py-2 text-white hover:bg-slate-700">Edytuj notatkę</a>
      {% endif %}
    </section>
  </div>
{% endblock %}
