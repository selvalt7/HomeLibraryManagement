{% extends "base.html.jinja" %}

{% block content %}
  <div class="space-y-6">
    <div class="rounded bg-white p-6 shadow-sm">
      <h1 class="text-4xl font-bold">{{ series.name }}</h1>
      <p class="mt-4 text-slate-600">{{ series.description|default:'Brak opisu serii.' }}</p>
      <p class="mt-4 text-slate-600">Posiadanych książek: {% if books %}{{ books|length }}{% else %}{{ series.book_set.count }}{% endif %}</p>
      {% if request.user.is_authenticated %}
        <a href="/series/{{ series.id }}/edit/" class="mt-4 inline-flex rounded bg-slate-800 px-4 py-2 text-white hover:bg-slate-700">Edytuj serię</a>
      {% endif %}
    </div>

    <section class="rounded bg-white p-6 shadow-sm">
      <h2 class="text-2xl font-semibold mb-4">Książki w serii</h2>
      <div class="space-y-4">
        {% if books %}
          {% for book in books %}
            <div class="rounded border border-slate-200 p-4 hover:border-slate-400">
              <a href="/book/{{ book.id }}/" class="text-xl font-medium text-blue-600 hover:underline">{{ book.title }}</a>
              <p class="text-slate-500">{{ book.published_date }}</p>
            </div>
          {% endfor %}
        {% else %}
          {% for book in series.book_set.all|dictsort:'published_date' %}
            <div class="rounded border border-slate-200 p-4 hover:border-slate-400">
              <a href="/book/{{ book.id }}/" class="text-xl font-medium text-blue-600 hover:underline">{{ book.title }}</a>
              <p class="text-slate-500">{{ book.published_date }}</p>
            </div>
          {% empty %}
            <p class="text-slate-500">Brak książek w tej serii.</p>
          {% endfor %}
        {% endif %}
      </div>
    </section>
  </div>
{% endblock %}
