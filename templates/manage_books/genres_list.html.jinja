{% extends "base.html.jinja" %}

{% block content %}
  <div class="space-y-6">
    <div class="rounded bg-white p-6 shadow-sm flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <h1 class="text-4xl font-bold">Gatunki</h1>
        <p class="mt-2 text-slate-600">Zarządzaj gatunkami literackimi w bibliotece.</p>
      </div>
      {% if request.user.is_authenticated %}
        <a href="/genre/add/" class="rounded bg-emerald-500 px-4 py-2 text-white hover:bg-emerald-400">Dodaj gatunek</a>
      {% endif %}
    </div>

    <section class="rounded bg-white p-6 shadow-sm">
      {% if genres %}
        <ul class="space-y-3">
          {% for genre in genres %}
            <li class="flex flex-wrap items-center justify-between gap-3 rounded border border-slate-200 p-4">
              <a href="/?genre={{ genre.id }}" class="text-lg font-medium text-blue-600 hover:underline">{{ genre.name }}</a>
              {% if request.user.is_authenticated %}
                <div class="flex gap-2">
                  <a href="/genre/{{ genre.id }}/edit/" class="rounded border border-slate-300 px-3 py-1 text-sm hover:bg-slate-50">Edytuj</a>
                  <a href="/genre/{{ genre.id }}/delete/" class="rounded border border-red-300 px-3 py-1 text-sm text-red-700 hover:bg-red-50">Usuń</a>
                </div>
              {% endif %}
            </li>
          {% endfor %}
        </ul>
      {% else %}
        <p class="text-slate-500">Brak gatunków w bazie.</p>
      {% endif %}
    </section>
  </div>
{% endblock %}
