{% extends "base.html.jinja" %}

{% block content %}
  <div class="flex flex-col gap-6">
    <div class="rounded bg-white p-6 shadow-sm">
      <h1 class="text-4xl font-bold">Moja biblioteka książek</h1>
      <p class="mt-2 text-slate-600">Przeglądaj wszystkie książki, ulubione pozycje, przeczytane tytuły oraz wybieraj filtrowanie według gatunku i tematu.</p>
    </div>

    <div class="grid gap-6 xl:grid-cols-[280px_1fr]">
      <aside class="space-y-6">
        {% if genre_name or topic_name or category_name or author_name or publisher_name or series_name or is_read or is_favorite %}
          <section class="rounded bg-blue-50 p-6 shadow-sm border border-blue-200">
            <h2 class="text-lg font-semibold mb-3 text-blue-900">Aktywne filtry</h2>
            <div class="space-y-2 text-sm">
              {% if genre_name %}
                <div class="bg-blue-100 px-3 py-2 rounded text-blue-900">
                  Gatunek: <strong>{{ genre_name }}</strong>
                </div>
              {% endif %}
              {% if topic_name %}
                <div class="bg-blue-100 px-3 py-2 rounded text-blue-900">
                  Temat: <strong>{{ topic_name }}</strong>
                </div>
              {% endif %}
              {% if category_name %}
                <div class="bg-blue-100 px-3 py-2 rounded text-blue-900">
                  Dział: <strong>{{ category_name }}</strong>
                </div>
              {% endif %}
              {% if author_name %}
                <div class="bg-blue-100 px-3 py-2 rounded text-blue-900">
                  Autor: <strong>{{ author_name }}</strong>
                </div>
              {% endif %}
              {% if publisher_name %}
                <div class="bg-blue-100 px-3 py-2 rounded text-blue-900">
                  Wydawca: <strong>{{ publisher_name }}</strong>
                </div>
              {% endif %}
              {% if series_name %}
                <div class="bg-blue-100 px-3 py-2 rounded text-blue-900">
                  Seria: <strong>{{ series_name }}</strong>
                </div>
              {% endif %}
              {% if is_read == 'true' %}
                <div class="bg-blue-100 px-3 py-2 rounded text-blue-900">
                  Status: <strong>Przeczytane</strong>
                </div>
              {% elif is_read == 'false' %}
                <div class="bg-blue-100 px-3 py-2 rounded text-blue-900">
                  Status: <strong>Nieprzeczytane</strong>
                </div>
              {% endif %}
              {% if is_favorite == 'true' %}
                <div class="bg-blue-100 px-3 py-2 rounded text-blue-900">
                  Status: <strong>Ulubione</strong>
                </div>
              {% endif %}
            </div>
            <a href="/" class="mt-4 inline-block rounded bg-blue-600 px-4 py-2 text-sm text-white hover:bg-blue-500">Wyczyść filtry</a>
          </section>
        {% endif %}

        <section class="rounded bg-white p-6 shadow-sm">
          <h2 class="text-2xl font-semibold mb-4">Szybki dostęp</h2>
          <div class="grid gap-3 sm:grid-cols-2">
            <a href="/authors/" class="rounded border border-slate-200 bg-slate-50 px-4 py-4 text-left text-blue-600 hover:border-slate-300 hover:bg-white">Przeglądaj autorów</a>
            <a href="/publishers/" class="rounded border border-slate-200 bg-slate-50 px-4 py-4 text-left text-blue-600 hover:border-slate-300 hover:bg-white">Przeglądaj wydawców</a>
            <a href="/series/" class="rounded border border-slate-200 bg-slate-50 px-4 py-4 text-left text-blue-600 hover:border-slate-300 hover:bg-white">Przeglądaj serie</a>
            <a href="/notes/" class="rounded border border-slate-200 bg-slate-50 px-4 py-4 text-left text-blue-600 hover:border-slate-300 hover:bg-white">Przeglądaj notatki</a>
          </div>
        </section>

        <section class="rounded bg-white p-6 shadow-sm">
          <h2 class="text-2xl font-semibold mb-4">Filtruj książki</h2>
          <div class="space-y-4">
            <div>
              <h3 class="font-semibold">Gatunki</h3>
              <ul class="mt-2 space-y-2 text-slate-700">
                {% for genre in genres %}
                  <li><a href="?genre={{ genre.id }}" class="text-blue-600 hover:underline {% if genre_id|stringformat:'s' == genre.id|stringformat:'s' %}font-bold text-blue-800{% endif %}">{{ genre.name }}</a></li>
                {% empty %}
                  <li class="text-slate-500">Brak gatunków do filtrowania.</li>
                {% endfor %}
              </ul>
            </div>

            <div>
              <h3 class="font-semibold">Tematy</h3>
              <ul class="mt-2 space-y-2 text-slate-700">
                {% for topic in topics %}
                  <li><a href="?topic={{ topic.id }}" class="text-blue-600 hover:underline {% if topic_id|stringformat:'s' == topic.id|stringformat:'s' %}font-bold text-blue-800{% endif %}">{{ topic.name }}</a></li>
                {% empty %}
                  <li class="text-slate-500">Brak tematów do filtrowania.</li>
                {% endfor %}
              </ul>
            </div>

            <div>
              <h3 class="font-semibold">Działy</h3>
              <ul class="mt-2 space-y-2 text-slate-700">
                {% for category in categories %}
                  <li><a href="?category={{ category.id }}" class="text-blue-600 hover:underline {% if category_id|stringformat:'s' == category.id|stringformat:'s' %}font-bold text-blue-800{% endif %}">{{ category.name }}</a></li>
                {% empty %}
                  <li class="text-slate-500">Brak działów do filtrowania.</li>
                {% endfor %}
              </ul>
            </div>

            <div>
              <h3 class="font-semibold">Autorzy</h3>
              <ul class="mt-2 space-y-2 text-slate-700 max-h-40 overflow-y-auto">
                {% for author in authors %}
                  <li><a href="?author={{ author.id }}" class="text-blue-600 hover:underline {% if author_id|stringformat:'s' == author.id|stringformat:'s' %}font-bold text-blue-800{% endif %}">{{ author.name }} {{ author.last_name }}</a></li>
                {% empty %}
                  <li class="text-slate-500">Brak autorów do filtrowania.</li>
                {% endfor %}
              </ul>
            </div>

            <div>
              <h3 class="font-semibold">Wydawcy</h3>
              <ul class="mt-2 space-y-2 text-slate-700 max-h-40 overflow-y-auto">
                {% for pub in publishers %}
                  <li><a href="?publisher={{ pub.id }}" class="text-blue-600 hover:underline {% if publisher_id|stringformat:'s' == pub.id|stringformat:'s' %}font-bold text-blue-800{% endif %}">{{ pub.name }}</a></li>
                {% empty %}
                  <li class="text-slate-500">Brak wydawców do filtrowania.</li>
                {% endfor %}
              </ul>
            </div>

            <div>
              <h3 class="font-semibold">Serie</h3>
              <ul class="mt-2 space-y-2 text-slate-700 max-h-40 overflow-y-auto">
                {% for s in series %}
                  <li><a href="?series={{ s.id }}" class="text-blue-600 hover:underline {% if series_id|stringformat:'s' == s.id|stringformat:'s' %}font-bold text-blue-800{% endif %}">{{ s.name }}</a></li>
                {% empty %}
                  <li class="text-slate-500">Brak serii do filtrowania.</li>
                {% endfor %}
              </ul>
            </div>

            <div>
              <h3 class="font-semibold">Status czytania</h3>
              <ul class="mt-2 space-y-2 text-slate-700">
                <li><a href="?is_read=true" class="text-blue-600 hover:underline {% if is_read == 'true' %}font-bold text-blue-800{% endif %}">Przeczytane</a></li>
                <li><a href="?is_read=false" class="text-blue-600 hover:underline {% if is_read == 'false' %}font-bold text-blue-800{% endif %}">Nieprzeczytane</a></li>
              </ul>
            </div>

            <div>
              <h3 class="font-semibold">Ulubione</h3>
              <ul class="mt-2 space-y-2 text-slate-700">
                <li><a href="?is_favorite=true" class="text-blue-600 hover:underline {% if is_favorite == 'true' %}font-bold text-blue-800{% endif %}">Tylko ulubione</a></li>
              </ul>
            </div>
          </div>
        </section>

        <section class="rounded bg-white p-6 shadow-sm">
          <h2 class="text-2xl font-semibold mb-4">Ulubione książki</h2>
          <ul class="space-y-3 text-slate-700">
            {% for book in favorite_books %}
              <li>
                <a href="/book/{{ book.id }}/" class="font-medium text-blue-600 hover:underline">{{ book.title }}</a>
                <div class="text-sm text-slate-500">{{ book.published_date }}</div>
              </li>
            {% empty %}
              <li class="text-slate-500">Nie dodałeś jeszcze ulubionych książek.</li>
            {% endfor %}
          </ul>
        </section>

        <section class="rounded bg-white p-6 shadow-sm">
          <h2 class="text-2xl font-semibold mb-4">Przeczytane książki</h2>
          <ul class="space-y-3 text-slate-700">
            {% for book in read_books %}
              <li>
                <a href="/book/{{ book.id }}/" class="font-medium text-blue-600 hover:underline">{{ book.title }}</a>
                <div class="text-sm text-slate-500">{{ book.published_date }}</div>
              </li>
            {% empty %}
              <li class="text-slate-500">Jeszcze nie oznaczyłeś żadnej książki jako przeczytanej.</li>
            {% endfor %}
          </ul>
        </section>
      </aside>

      <section class="rounded bg-white p-6 shadow-sm">
        <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
          <div>
            <h2 class="text-2xl font-semibold">Wszystkie książki</h2>
            <p class="mt-1 text-slate-600">Kliknij tytuł, aby przejść do szczegółów książki.</p>
          </div>
          {% if request.user.is_authenticated %}
            <a href="/book/add/" class="inline-flex items-center rounded bg-emerald-500 px-4 py-2 text-white hover:bg-emerald-400">Dodaj nową książkę</a>
          {% endif %}
        </div>

        <div class="mt-6 overflow-x-auto">
          <table class="min-w-full divide-y divide-slate-200 text-left text-sm">
            <thead class="bg-slate-50 text-slate-700">
              <tr>
                <th class="px-4 py-3">Tytuł</th>
                <th class="px-4 py-3">Autor</th>
                <th class="px-4 py-3">Wydawca</th>
                <th class="px-4 py-3">Status</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-200 bg-white">
              {% for book in books %}
                <tr>
                  <td class="px-4 py-3"><a href="/book/{{ book.id }}/" class="font-medium text-blue-600 hover:underline">{{ book.title }}</a></td>
                  <td class="px-4 py-3 text-slate-700">{% if book.authors.all %}{% for author in book.authors.all %}{{ author.name }} {{ author.last_name }}{% if not forloop.last %}, {% endif %}{% endfor %}{% else %}{{ book.author }}{% endif %}</td>
                  <td class="px-4 py-3 text-slate-700">{{ book.publisher.name }}</td>
                  <td class="px-4 py-3 text-slate-700">{% if book.is_favorite %}Ulubiona{% elif book.is_read %}Przeczytana{% else %}Nowa{% endif %}</td>
                </tr>
              {% empty %}
                <tr>
                  <td class="px-4 py-6 text-slate-500" colspan="4">Brak książek w bibliotece.</td>
                </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </section>
    </div>
  </div>
{% endblock %}
