{% extends "base.html.jinja" %}

{% block content %}
  <div class="space-y-6">
    <div class="rounded bg-white p-6 shadow-sm">
      <h1 class="text-4xl font-bold">Lista notatek</h1>
      <p class="mt-2 text-slate-600">Przeglądaj wszystkie notatki powiązane z książkami.</p>
    </div>

    <section class="rounded bg-white p-6 shadow-sm">
      {% if notes %}
        <div class="space-y-4">
          {% for note in notes %}
            <article class="rounded border border-slate-200 p-5 hover:border-slate-400">
              <div class="flex items-start justify-between gap-4">
                <div>
                  <a href="/note/{{ note.id }}/" class="text-xl font-semibold text-blue-600 hover:underline">Notatka do: {{ note.book.title }}</a>
                  <p class="mt-2 text-slate-500 whitespace-pre-line">{{ note.content|truncatechars:120 }}</p>
                </div>
                <span class="rounded-full bg-slate-100 px-3 py-1 text-xs uppercase tracking-[0.2em] text-slate-600">{{ note.created_at|date:"Y-m-d H:i" }}</span>
              </div>
            </article>
          {% endfor %}
        </div>
      {% else %}
        <p class="text-slate-500">Brak notatek w bazie.</p>
      {% endif %}
    </section>
  </div>
{% endblock %}
