<!DOCTYPE html>
<html lang="pl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  <title>Home Library Management</title>
</head>
<body class="min-h-screen bg-slate-50 text-slate-900">
  <header class="bg-slate-900 text-white">
    <div class="mx-auto max-w-7xl px-4 py-4 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <a href="/" class="text-2xl font-semibold">Home Library</a>
        <p class="text-sm text-slate-300">Ewidencja biblioteczna</p>
      </div>
      <nav class="flex flex-wrap items-center gap-3 text-sm">
        <a href="/" class="rounded bg-slate-700 px-3 py-2 hover:bg-slate-600">Strona główna</a>
        <a href="/authors/" class="rounded bg-slate-700 px-3 py-2 hover:bg-slate-600">Autorzy</a>
        <a href="/publishers/" class="rounded bg-slate-700 px-3 py-2 hover:bg-slate-600">Wydawcy</a>
        <a href="/series/" class="rounded bg-slate-700 px-3 py-2 hover:bg-slate-600">Serie</a>
        <a href="/notes/" class="rounded bg-slate-700 px-3 py-2 hover:bg-slate-600">Notatki</a>
        {% if request.user.is_authenticated %}
          <a href="/book/add/" class="rounded bg-emerald-500 px-3 py-2 text-white hover:bg-emerald-400">Dodaj książkę</a>
          <span class="rounded border border-slate-600 px-3 py-2">{{ request.user.username }}</span>
          <a href="/logout/" class="rounded bg-red-500 px-3 py-2 text-white hover:bg-red-400">Wyloguj</a>
        {% else %}
          <a href="/login/" class="rounded bg-blue-600 px-3 py-2 text-white hover:bg-blue-500">Zaloguj się</a>
          <a href="/signup/" class="rounded bg-slate-700 px-3 py-2 hover:bg-slate-600">Rejestracja</a>
        {% endif %}
      </nav>
    </div>
  </header>
  <main class="mx-auto max-w-7xl px-4 py-8">
    {% if messages %}
      <section class="space-y-2 mb-6">
        {% for message in messages %}
          <div class="rounded border px-4 py-3 {% if message.tags %}bg-{{ message.tags }}-100 text-{{ message.tags }}-900{% else %}bg-slate-100 text-slate-900{% endif %}">
            {{ message }}
          </div>
        {% endfor %}
      </section>
    {% endif %}
    {% block content %}{% endblock %}
  </main>
  <footer class="border-t bg-white py-6">
    <div class="mx-auto max-w-7xl px-4 text-sm text-slate-500">
      <p>Home Library Management System — zarządzanie osobistą biblioteką książek.</p>
    </div>
  </footer>
</body>
</html>
